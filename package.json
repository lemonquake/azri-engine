{
  "name": "temp_project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "test:browser": "vite --open"
  },
  "build": {
    "appId": "com.azri.engine",
    "productName": "Azri Engine",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fontsource/vt323": "^5.2.7",
    "@pixi/filter-glow": "^5.2.1",
    "@pixi/react": "^8.0.5",
    "@types/animejs": "^3.1.13",
    "@types/matter-js": "^0.20.2",
    "@types/sql.js": "^1.4.9",
    "animejs": "^3.2.2",
    "clsx": "^2.1.1",
    "electron-is-dev": "^3.0.1",
    "gifenc": "^1.0.3",
    "ip": "^2.0.1",
    "jszip": "^3.10.1",
    "locally": "^0.2.1",
    "localtunnel": "^2.0.2",
    "lucide-react": "^0.563.0",
    "matter-js": "^0.20.0",
    "peerjs": "^1.5.5",
    "pixi.js": "^8.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/ip": "^1.1.3",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "peer": "^1.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.4"
  }
}
